<?xml version="1.0" encoding="UTF-8"?>
<window>
    <defaultcontrol always="true">2000</defaultcontrol>
    <controls>
        <!-- Background -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="FF000000">fen_common/white.png</texture>
            <animation effect="fade" end="85" time="120">WindowOpen</animation>
        </control>
        <control type="group">
            <top>301</top>
            <left>340</left>
            <animation effect="fade" end="100" time="200">WindowOpen</animation>
            <control type="image">
                <height>478</height>
                <width>1240</width>
                <texture colordiffuse="$INFO[Window(10000).Property(fen.window_theme)]" border="30">fen_common/circle.png</texture>
            </control>
            <control type="group">
                <left>10</left>
                <!-- Logo and Tips/Clock & Date -->
                <control type="image">
                    <top>10</top>
                    <left>1170</left>
                    <width>50</width>
                    <height>50</height>
                    <aspectratio aligny="top">keep</aspectratio>
                    <texture>$INFO[Window(10000).Property(fen.addon_icon)]</texture>
                </control>
                <!-- People List -->
                <control type="group">
                    <height>50</height>
                    <left>20</left>
                    <control type="label">
                        <top>10</top>
                        <width min="30" max="1130">auto</width>
                        <height>20</height>
                        <font>font13</font> <!-- FEN_30 -->
                        <textcolor>FFCCCCCC</textcolor>
                        <label>[B]$INFO[Window.Property(list_heading)] | [/B]$INFO[Container(2000).ListItem.Property(display)]</label>
                    </control>
                    <control type="fixedlist" id="2000">
                        <animation effect="slide" end="-472,0" time="0" condition="Integer.IsEqual(Container(2000).NumItems,1) | Integer.IsEqual(Container(2000).NumItems,2)">Conditional</animation>
                        <animation effect="slide" end="-236,0" time="0" condition="Integer.IsEqual(Container(2000).NumItems,3) | Integer.IsEqual(Container(2000).NumItems,4)">Conditional</animation>
                        <pagecontrol>4000</pagecontrol>
                        <top>60</top>
                        <width>1180</width>
                        <height>360</height>
                        <onup>4000</onup>
                        <ondown>4000</ondown>
                        <orientation>horizontal</orientation>
                        <scrolltime tween="sine">500</scrolltime>
                        <focusposition>2</focusposition>
                        <movement>2</movement>
                        <itemlayout height="360" width="236">
                            <control type="image">
                                <left>8</left>
                                <top>8</top>
                                <height max="344">auto</height>
                                <width max="220">auto</width>
                                <aspectratio>keep</aspectratio>
                                <texture diffuse="fen_diffuse/poster-50.png" background="true">$INFO[ListItem.Property(thumbnail)]</texture>
                            </control>
                        </itemlayout>
                        <focusedlayout height="360" width="236">
                            <control type="image">
                                <animation effect="fade" start="100" end="60" condition="Control.HasFocus(4000)">Conditional</animation>
                                <animation type="Focus" reversible="false">
                                    <effect type="zoom" end="105" time="75" tween="sine" easing="out" center="auto" />
                                    <effect type="zoom" end="95" time="225" tween="sine" delay="100" easing="out" center="auto" />
                                </animation>
                                <left>0</left>
                                <top>5</top>
                                <height>350</height>
                                <width>236</width>
                                <texture colordiffuse="FFCCCCCC">fen_diffuse/poster-50.png</texture>
                                <visible>Control.HasFocus(2000) | Control.HasFocus(4000)</visible>
                            </control>
                            <control type="image">
                                <left>8</left>
                                <top>8</top>
                                <height max="344">auto</height>
                                <width max="220">auto</width>
                                <aspectratio>keep</aspectratio>
                                <texture diffuse="fen_diffuse/poster-50.png" background="true">$INFO[ListItem.Property(thumbnail)]</texture>
                            </control>
                        </focusedlayout>
                    </control>
                    <control type="scrollbar" id="4000">
                        <left>5</left>
                        <top>432</top>
                        <width>1170</width>
                        <height>15</height>
                        <onup>2000</onup>
                        <ondown>2000</ondown>
                        <texturesliderbackground colordiffuse="FF1F2020">fen_common/white.png</texturesliderbackground>
                        <texturesliderbar colordiffuse="FF555556">fen_common/white.png</texturesliderbar>
                        <texturesliderbarfocus colordiffuse="FFCCCCCC">fen_common/white.png</texturesliderbarfocus>
                        <showonepage>false</showonepage>
                        <orientation>Horizontal</orientation>
                    </control>
                    <control type="image">
                        <top>215</top>
                        <left>20</left>
                        <width>25</width>
                        <height>25</height>
                        <texture colordiffuse="CCCCCCCC" background="true">fen_common/arrow_left.png</texture>
                        <visible>Control.HasFocus(4000)] + Container(2000).HasPrevious</visible>
                    </control>
                    <control type="image">
                        <top>215</top>
                        <left>1135</left>
                        <width>25</width>
                        <height>25</height>
                        <texture colordiffuse="CCCCCCCC" background="true" flipx="true">fen_common/arrow_left.png</texture>
                        <visible>Control.HasFocus(4000)] + Container(2000).HasNext</visible>
                    </control>
                </control>
            </control>
        </control>
    </controls>
</window>