<advancedsettings version="1.0">
    <!-- Crafted by donutmiddles with assistance from GPT-5.5 Thinking, 2026-07-07 -->
    <!-- Profile: Universal low-end / lightweight devices -->

    <!-- Startup -->
    <splash>false</splash>
    <!-- Disable Kodi splash screen for slightly cleaner/faster startup -->

    <!--
        Kodi Omega / v21+ cache settings

        Cache settings are configured in Kodi's GUI, not advancedsettings.xml:

        Settings > Services > Caching

        The advancedsettings.xml cache tags shown below are deprecated/ignored
        in Kodi Omega / v21+ and are included only as documentation of intended values.

        Universal low-end / lightweight playback baseline:
        - Buffer mode: Broadest appropriate network/internet buffer mode

          Recommended broad starting point for network-backed playback. In Kodi's
          GUI, choose the broadest buffer mode that fits the playback path, such as
          HTTP/HTTPS add-ons or servers, FTP/WebDAV paths, SMB/NFS shares, or
          reverse-proxy setups. Use a narrower buffer mode only if you know the
          playback path and the device behaves better with less buffering.

        - Memory size: 64-128 MB

          Start with 64 MB on older, entry-level, or 1 GB RAM devices.

          Use 128 MB on stronger low-end / 2 GB-class devices only if Kodi remains
          responsive and the OS is not showing memory pressure, app reloads, or UI lag.

          Avoid 256 MB+ on low-end profiles unless testing proves it helps.
          Leave enough memory for Kodi, the skin, add-ons, subtitles, artwork,
          OS background services, and decoder overhead.

        - Read factor: Adaptive if available, otherwise 4x

          Adaptive is preferred because it can read more aggressively when the cache
          is empty/low, then throttle back once the cache is healthy. If Adaptive is
          unavailable, 4x is Kodi's default baseline and is safer than aggressive read
          factors on weaker hardware.

        - Chunk size:
            * Default: 128 KB
            * Start at 128 KB
            * Test 256 KB only if needed

            "If needed" means playback still pauses, buffers, stutters, or takes too
            long to refill during high-bitrate scenes after the basics are already
            healthy: direct/native playback is working, the server/storage can keep up, the device
            is not struggling, and the network is stable.

            Do not increase chunk size just because a larger value exists.
            If playback is already smooth, leave it alone.

            * Avoid 512 KB or 1 MB on low-end profiles unless 256 KB has already been
              tested and playback still pauses, buffers, or refills too slowly.

        Example historical cache block included for reference only:

        <cache>
            <memorysize>134217728</memorysize>
            <buffermode>1</buffermode>
            <readfactor>4</readfactor>
        </cache>
    -->

    <!-- Network / HTTP / NFS behavior -->
    <network>
        <curlclienttimeout>20</curlclienttimeout>
        <!--
            Seconds before Kodi gives up on an unresponsive HTTP/HTTPS request.

            20 seconds gives Kodi a more responsive failure point when a remote server,
            reverse proxy, NAS-backed media path, add-on, CDN, or temporarily busy source
            does not respond quickly enough.

            Use 30 seconds instead if your media source is known to be slow to wake,
            remote, overloaded, or more stable with extra connection time.
        -->

        <curllowspeedtime>20</curllowspeedtime>
        <!--
            Seconds a transfer may remain below Kodi's low-speed threshold before being
            treated as failed.

            This helps Kodi fail stalled HTTP/HTTPS transfers instead of waiting indefinitely.
        -->

        <curlretries>2</curlretries>
        <!--
            Retry failed curl transfers twice before giving up.

            Useful for occasional transient HTTP/HTTPS failures through reverse proxies,
            add-ons, remote servers, CDNs, or unstable network paths.
        -->

        <curlkeepaliveinterval>30</curlkeepaliveinterval>
        <!--
            Enable TCP keepalive probes for curl-supported connections.

            Helps long-running HTTP/HTTPS streams stay alive across network devices,
            proxies, NAT, and reverse-proxy paths.
        -->

        <!--
            IPv6 troubleshooting

            Leave this omitted by default.
            Enable only if a specific device, operating system, router,
            DNS path, VPN path, or ISP has broken IPv6 behavior.

            <disableipv6>true</disableipv6>
        -->

        <!--
            HTTP/2 troubleshooting

            Leave this omitted by default.
            Enable only if Kodi playback is unstable with a specific HTTP/2 server,
            reverse proxy, add-on, or CDN path.

            <disablehttp2>true</disablehttp2>
        -->

        <nfstimeout>30</nfstimeout>
        <!--
            NFS access timeout in seconds.

            30 seconds gives a NAS, media server, or busy storage backend more tolerance
            during wake-up, disk spin-up, temporary I/O delay, or heavy scan/import load.

            Applies only to Kodi's internal NFS client.
        -->

        <nfsretries>0</nfsretries>
        <!--
            Disable extra Kodi-level NFS retries after the timeout is reached.

            Kodi treats 0 as disabled and -1 as unlimited retries.

            For high-bitrate playback, this avoids long repeated retry loops if the NFS server,
            NAS, disk, or network path becomes genuinely unresponsive.

            The intent is: wait long enough once, then fail cleanly rather than hanging through
            repeated retries.

            Applies only to Kodi's internal NFS client.
        -->
    </network>

    <!-- Samba / SMB behavior -->
    <samba>
        <clienttimeout>30</clienttimeout>
        <!-- SMB client timeout in seconds -->

        <statfiles>true</statfiles>
        <!--
            true allows Kodi to stat files normally.
            If browsing very large SMB directories is slow, testing false may improve listing speed.
            For HTTP-based playback, this usually has little impact.
        -->
    </samba>

    <!-- Artwork / texture cache quality -->
    <fanartres>1080</fanartres>
    <!--
        1080 is safer for low-end / lightweight devices.
        Use 720 only if the UI remains sluggish or texture cache size becomes an issue.
    -->

    <imageres>720</imageres>
    <!--
        720 keeps posters/thumbs lighter for low-memory or weaker devices.

        Use 1080 only if the UI remains smooth and storage pressure is not an issue.
    -->

    <imagequalityjpeg>4</imagequalityjpeg>
    <!--
        Kodi default compromise between artwork quality and thumbnail/cache size.

        Avoid 0-3 on low-end profiles unless the device is clearly responsive
        and maximum artwork quality matters more than storage usage and UI speed.
    -->

    <!--
        Android / passthrough stability

        Leave commented by default.
        Enable only on Android-based devices that actually show passthrough drift,
        delayed audio start, occasional video stutter during passthrough, or audio/video
        sync weirdness.

        Start conservatively. Kodi default is 10 ms; 25 ms is a reasonable first
        troubleshooting value. Higher values should only be tested if clearly needed.

        <audio>
            <maxpassthroughoffsyncduration>25</maxpassthroughoffsyncduration>
        </audio>
    -->

    <!-- Playback controls / watched status -->
    <video>
        <fpsdetect>1</fpsdetect>
        <!--
            FPS detection method for video playback.

            0 = trust the FPS reported by the codec/container.
            1 = recalculate FPS from video timestamps when frame timing appears uniform.
            2 = always recalculate FPS from video timestamps.

            Keep at 1 for broad compatibility. It gives Kodi a chance to correct
            inaccurate container-reported FPS while avoiding the more aggressive
            always-recalculate behavior of 2.

            This can help Kodi choose correct playback timing and display refresh behavior,
            especially when "Adjust display refresh rate" is enabled.
        -->

        <playcountminimumpercent>95</playcountminimumpercent>
        <!-- Mark video watched after 95% completion -->

        <ignoresecondsatstart>180</ignoresecondsatstart>
        <!-- Seconds to ignore at the start of a video before making a resume point -->

        <ignorepercentatend>5</ignorepercentatend>
        <!-- Percent at the end of a video to ignore to prevent making a resume point -->

        <subsdelayrange>240</subsdelayrange>
        <!-- Allows subtitle delay adjustment up to +/- 240 seconds -->

        <!--
            Optional subtitle positioning for large TV playback.

            Leave commented by default because preferred subtitle placement varies by
            screen size, skin, device, display overscan, and seating distance.

            <subtitleverticalmargin>120</subtitleverticalmargin>
        -->
    </video>

</advancedsettings>
